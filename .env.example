DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rotary_connect
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440
# Yoola SMS gateway key. Leave blank to disable SMS (calls are skipped, not
# errored) — useful for local dev without spending SMS credits.
YOOLA_API_KEY=
# Cloudflare R2 (S3-compatible object storage) for gallery photos. Leave
# blank to disable — gallery upload/list are skipped, not errored.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rotary-connect-gallery
R2_PUBLIC_URL=
